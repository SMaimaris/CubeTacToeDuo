;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CubeTacToe"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.5", "C#", "Forward Plus")
config/icon="uid://c0xxnosno5few"

[autoload]

GameSettings="*res://scripts/autoload/GameSettings.cs"
AudioManager="*res://scripts/autoload/AudioManager.cs"
NetworkManager="*res://scripts/autoload/NetworkManager.cs"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[dotnet]

project/assembly_name="CubeTacToe"

[gui]

theme/custom="res://themes/MedievalTheme.tres"
theme/custom_font_size=18

